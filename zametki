python -m venv env  команда на окружение
env\Scripts\activate    активация
pip freeze > requirements.txt    запись установленных пакетов
pip install -r requirements.txt    #восстановление окружения

pwd - путь к текущей директории
ls - содержимое директории
ls -a скрытые файлы тоже покажет
ls -al с правами показывает файлы
ls --help выводит документацию конкретной команды

/home/Snezh1k - абсотюный путь
home/Snezh1k - относительный путь

cd <путь> - перейти по указанному пути
cd .. - перейти в родительскую директорию
cd ~ - перейти в папку пользователя
cd / - перейти в корень

mkdir <имя папки> - создание папки
touch <имя папки> - создание файла

rm - удаление
rm -r рекурсивное удаление (для папок)
mv - перемещение / переименовывание
cp - копирование (что куда)
cp -r - копирование для папок

nano main.py - создание файла, в редакторе
cat main.py - просмотр содержимого файла